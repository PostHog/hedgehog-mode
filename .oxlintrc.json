{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "vitest", "nextjs"],
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "ignorePatterns": ["node_modules", "dist", ".next"],
  "rules": {
    "no-console": "off",
    "no-unused-vars": [
      "error",
      {
        "ignoreRestSiblings": true,
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_"
      }
    ],
    "react-hooks/exhaustive-deps": "off",
    "react-hooks/rules-of-hooks": "error"
  },
  "overrides": [
    {
      "files": ["hedgehog-mode/src/**/*.{js,jsx,ts,tsx}"],
      "rules": {
        "no-console": "error"
      }
    }
  ]
}
